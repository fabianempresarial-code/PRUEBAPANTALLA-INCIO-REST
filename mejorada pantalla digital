<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Menú Premium Tamarindo - Logo Personalizado</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;600;800&family=Playfair+Display:wght@700&display=swap" rel="stylesheet">
    <style>
        :root {
            --gold: #d4af37;
            --gold-light: #f1d592;
            --dark: #020617;
            --neon-green: #22c55e;
            --glass-opacity: rgba(15, 23, 42, 0.75); 
        }

        body {
            margin: 0; padding: 0;
            font-family: 'Poppins', sans-serif;
            background: #000;
            color: white;
            height: 100vh;
            overflow: hidden;
            display: flex; flex-direction: column;
        }

        /* CAPA DE FONDO PERSONALIZADO */
        #custom-bg {
            position: fixed;
            top: 0; left: 0;
            width: 100%; height: 100%;
            z-index: -2;
            background-size: cover;
            background-position: center;
            transition: background-image 2s ease-in-out;
            filter: brightness(0.4);
        }

        .overlay-motion {
            position: fixed;
            top: 0; left: 0;
            width: 100%; height: 100%;
            z-index: -1;
            background: linear-gradient(135deg, rgba(2, 6, 23, 0.8) 0%, rgba(30, 41, 59, 0.4) 100%);
            backdrop-filter: blur(5px);
        }

        header {
            height: 12vh;
            display: flex; justify-content: space-between; align-items: center;
            padding: 0 5%;
            background: rgba(0,0,0,0.8);
            border-bottom: 3px solid var(--gold);
            z-index: 10;
        }

        /* ESTILOS DEL LOGO */
        .logo-container {
            height: 80%; /* Ajusta el logo al alto del header */
            display: flex;
            align-items: center;
        }

        .logo-container img {
            max-height: 100%;
            width: auto;
            object-fit: contain;
            filter: drop-shadow(0 0 10px rgba(212, 175, 55, 0.5));
        }

        .day-badge {
            background: var(--gold);
            color: var(--dark);
            padding: 8px 35px;
            border-radius: 5px;
            font-weight: 800;
            font-size: 1.6rem;
            box-shadow: 0 0 20px var(--gold);
        }

        /* CARRUSEL HORIZONTAL */
        main {
            flex: 1;
            overflow: hidden;
            display: flex;
            align-items: center;
        }

        .menu-track {
            display: flex;
            width: max-content;
            animation: scrollHorizontal 45s linear infinite;
        }

        @keyframes scrollHorizontal {
            0% { transform: translateX(0); }
            100% { transform: translateX(-50%); }
        }

        /* TARJETAS */
        .card {
            background: var(--glass-opacity);
            border: 2px solid rgba(34, 197, 94, 0.4);
            border-radius: 40px;
            margin: 0 30px;
            width: 500px;
            height: 550px;
            overflow: hidden;
            display: flex; flex-direction: column;
            backdrop-filter: blur(15px);
            box-shadow: 0 0 30px rgba(34, 197, 94, 0.1);
            animation: liquidFloat 6s ease-in-out infinite;
        }

        @keyframes liquidFloat {
            0%, 100% { transform: translateY(0) rotate(-0.5deg); }
            50% { transform: translateY(-20px) rotate(0.5deg); }
        }

        .img-container {
            width: 100%; height: 55%;
            overflow: hidden;
            border-bottom: 2px solid var(--gold);
        }

        .img-container img {
            width: 100%; height: 100%;
            object-fit: cover;
            animation: slowZoom 12s linear infinite alternate;
        }

        @keyframes slowZoom {
            from { transform: scale(1); }
            to { transform: scale(1.2); }
        }

        .info {
            padding: 25px;
            text-align: center;
            flex: 1;
            display: flex; flex-direction: column; justify-content: center;
        }

        .content {
            font-size: 2.2rem;
            font-weight: 800;
            line-height: 1.1;
            color: var(--neon-green);
            text-shadow: 0 0 15px rgba(34, 197, 94, 0.6);
        }

        footer {
            height: 10vh;
            background: var(--gold);
            color: var(--dark);
            display: flex; justify-content: space-around; align-items: center;
            font-weight: 800; font-size: 2.2rem;
            z-index: 10;
        }
    </style>
</head>
<body>

    <div id="custom-bg"></div>
    <div class="overlay-motion"></div>

    <header>
        <div class="logo-container">
            <!-- El logo se carga dinámicamente desde el Script -->
            <img id="custom-logo" src="" alt="Logo Tamarindo">
        </div>
        <div id="label-dia" class="day-badge">...</div>
    </header>

    <main>
        <div class="menu-track" id="menu-track">
            <!-- Cargando contenido... -->
        </div>
    </main>

    <footer>
        <div>MESA: $15.000</div>
        <div>DOMI: $16.000</div>
        <div style="font-size: 1.2rem;">📍 Cra 11 # 64 - 10 | Parque Lourdes</div>
    </footer>

    <script>
        const CONFIG = {
            // URL DE TU LOGO (PNG transparente recomendado)
            logoUrl: "https://i.imgur.com/3FvWdgi.gif",
            
            csvUrl: "https://docs.google.com/spreadsheets/d/e/2PACX-1vS29H3hxA9X8VcqQqGZlT4duXOIT3xAdIhExEIut9frN0i78naYSj6gnWFkWliWwKNLT5tGNlaYh16j/pub?output=csv",
            defaultImg: "https://images.unsplash.com/photo-1504674900247-0877df9cc836?q=80&w=1000",
            defaultBg: "https://images.unsplash.com/photo-1514362545857-3bc16c4c7d1b?q=80&w=1500"
        };

        // Cargar el logo inmediatamente
        if(CONFIG.logoUrl) {
            document.getElementById('custom-logo').src = CONFIG.logoUrl;
        }

        async function updateMenu() {
            try {
                const res = await fetch(`${CONFIG.csvUrl}&nocache=${Date.now()}`);
                const text = await res.text();
                const data = text.split('\n').map(row => row.split(',').map(c => c.trim()));
                render(data);
            } catch (e) { console.error("Error cargando datos"); }
        }

        function render(data) {
            const dias = ["DOMINGO", "LUNES", "MARTES", "MIERCOLES", "JUEVES", "VIERNES", "SABADO"];
            const hoy = dias[new Date().getDay()];
            
            let fila = data.find(r => r[0] && r[0].toUpperCase() === hoy) || data[1];
            let filaImagenes = data.find(r => r[0] && r[0].toLowerCase().includes("imagenes")) || [];

            const bgUrl = filaImagenes[0] && filaImagenes[0].startsWith('http') ? filaImagenes[0] : CONFIG.defaultBg;
            document.getElementById('custom-bg').style.backgroundImage = `url('${bgUrl}')`;

            document.getElementById('label-dia').innerText = hoy;

            const items = [
                { t: "Principios", c: fila[1], img: filaImagenes[1] || CONFIG.defaultImg },
                { t: "Proteínas", c: fila[2], img: filaImagenes[2] || CONFIG.defaultImg },
                { t: "Acompañantes", c: fila[3], img: filaImagenes[3] || CONFIG.defaultImg },
                { t: "Bebida", c: fila[5] || "Jugo Natural", img: filaImagenes[5] || CONFIG.defaultImg }
            ];

            const track = document.getElementById('menu-track');
            const html = items.map(p => `
                <div class="card">
                    <div class="img-container">
                        <img src="${p.img}" alt="${p.t}">
                    </div>
                    <div class="info">
                        <h2 style="color: var(--gold-light); font-size: 0.9rem; letter-spacing: 3px;">${p.t}</h2>
                        <div class="content">${p.c || '---'}</div>
                    </div>
                </div>
            `).join('');

            track.innerHTML = html + html + html;
        }

        updateMenu();
        setInterval(updateMenu, 300000); // 5 min
    </script>
</body>
</html>
